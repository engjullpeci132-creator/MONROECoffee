{
  "entities": {
    "MenuItem": {
      "title": "MenuItem",
      "description": "A food or drink item on the cafe menu.",
      "type": "object",
      "properties": {
        "title": { "type": "string", "description": "The name of the item." },
        "description": { "type": "string", "description": "A brief description of the item." },
        "price": { "type": "string", "description": "The price of the item (e.g., €4.50)." },
        "image": { "type": "string", "description": "URL to the item's image." },
        "category": { "type": "string", "description": "e.g., Signature, Cold Brew, Pastry" },
        "order": { "type": "number", "description": "Display order." }
      },
      "required": ["title", "price", "image", "category"]
    },
    "Reservation": {
      "title": "Reservation",
      "description": "A table booking request.",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Customer name." },
        "email": { "type": "string", "description": "Customer email." },
        "date": { "type": "string", "description": "Date of reservation (YYYY-MM-DD)." },
        "time": { "type": "string", "description": "Time of reservation (HH:mm)." },
        "guests": { "type": "number", "description": "Number of guests." },
        "status": { "type": "string", "enum": ["pending", "confirmed", "cancelled"], "description": "Current status." },
        "userId": { "type": "string", "description": "ID of the user who made the reservation (if logged in)." },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "email", "date", "time", "guests", "status"]
    },
    "User": {
      "title": "User",
      "description": "User profile potentially containing role info.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "customer"] }
      },
      "required": ["uid", "email", "role"]
    }
  },
  "firestore": {
    "menu_items/{itemId}": {
      "schema": "MenuItem",
      "description": "Global menu items."
    },
    "reservations/{reservationId}": {
      "schema": "Reservation",
      "description": "All table reservations."
    },
    "users/{userId}": {
      "schema": "User",
      "description": "User profiles and roles."
    }
  }
}
